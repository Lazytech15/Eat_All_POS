{
  "name": "eatall-pos",
  "version": "1.0.0",
  "description": "Offline-capable POS System built with Electron + React Vite",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "vite": "vite",
    "electron": "electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.eatall.pos",
    "productName": "Eat-All POS",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/assets/**/*",
      "splash.html",
      "node_modules/better-sqlite3/**/*"
    ],
    "icon": "src/assets/Eatall.png",
    "mac": {
      "category": "public.app-category.business",
      "icon": "src/assets/Eatall.png"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/Eatall.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/Eatall.png"
    }
  }
}